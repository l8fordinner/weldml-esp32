      "required": true
    },
    {
      "index": 18,
      "name": "PlungeVelocity",
      "source_column_or_formula": "plunge velocity",
      "units": "source velocity units",
      "required": true
    },
    {
      "index": 19,
      "name": "RMS",
      "source_column_or_formula": "root mean square",
      "units": "source signal units",
      "required": true
    },
    {
      "index": 20,
      "name": "ShapeFactor",
      "source_column_or_formula": "time-domain shape factor",
      "units": "unitless",
      "required": true
    },
    {
      "index": 21,
      "name": "StandardDeviation",
