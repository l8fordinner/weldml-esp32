# Board: Generic ESP32 (ESP32-WROOM-32 / ESP32-WROVER)
# Chip:  ESP32 — dual-core Xtensa LX6, classic BT + BLE 4.2, no native USB

# Chip capability flags
CONFIG_BOARD_DUAL_CORE=y
CONFIG_BOARD_HAS_BT_CLASSIC=y
CONFIG_BOARD_HAS_BLE=y
CONFIG_BOARD_HAS_WIFI=y
CONFIG_BOARD_HAS_NATIVE_USB=n
CONFIG_BOARD_HAS_ZIGBEE=n

# Flash
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHFREQ_80M=y
CONFIG_ESPTOOLPY_FLASHMODE_DIO=y

# PSRAM (disable for WROOM; enable for WROVER)
CONFIG_ESP32_SPIRAM_SUPPORT=n
